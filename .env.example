PROJECT_NAME=eastman-adms-server
APP_NAME=eastman-adms-server
APP_ENV=production
APP_PORT=4370
TZ=Asia/Dubai
LOG_LEVEL=info
MINGDAO_API_TOKEN=changeme-mingdao-token
USER_SYNC_MAX_RETRY=3
USER_SYNC_ACK_TIMEOUT_SECONDS=120
MINGDAO_ATTENDANCE_SYNC_ENABLED=false
MINGDAO_ATTENDANCE_OPENAPI_URL=
MINGDAO_ATTENDANCE_APP_KEY=
MINGDAO_ATTENDANCE_SIGN=
MINGDAO_ATTENDANCE_WORKSHEET_ID=
MINGDAO_ATTENDANCE_FIELD_EMPLOYEE_RECORD_ID=
MINGDAO_ATTENDANCE_FIELD_CHECK_TIME=
MINGDAO_ATTENDANCE_FIELD_CHECK_DATE=
MINGDAO_ATTENDANCE_FIELD_DEVICE_NAME=
MINGDAO_ATTENDANCE_FIELD_DEVICE_SN=
ADMS_BACKUP_ENABLED=true
ADMS_BACKUP_TIME=03:30
ADMS_BACKUP_RETENTION_COUNT=14
ADMS_BACKUP_HOST_DIR=/opt/eastman/Eastman-adms-server/backups
ADMS_BACKUP_CONTAINER_DIR=/app/backup

MYSQL_IMAGE=docker.m.daocloud.io/library/mysql:8.4
PYTHON_IMAGE=docker.m.daocloud.io/library/python:3.12
API_IMAGE=eastman-adms-server:latest

MYSQL_HOST=mysql
MYSQL_PORT=3306
MYSQL_DATABASE=eastman_adms
MYSQL_USERNAME=eastman_adms
MYSQL_PASSWORD=PLEASE_CHANGE_ME
